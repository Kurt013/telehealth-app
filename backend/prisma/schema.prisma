generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PATIENT
  DOCTOR
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum ConsultationSessionStatus {
  SCHEDULED
  IN_PROGRESS
  ENDED
  CANCELLED
}

enum NotificationType {
  APPOINTMENT_BOOKED
  APPOINTMENT_RESCHEDULED
  APPOINTMENT_CANCELLED
  SESSION_READY
  SESSION_STARTED
  SESSION_ENDED
  NOTE_CREATED
  PRESCRIPTION_CREATED
}

model Account {
  id String @id @default(uuid())

  email        String @unique
  passwordHash String

  role Role

  isVerified Boolean @default(false)

  patientProfile PatientProfile?
  doctorProfile  DoctorProfile?

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  notifications Notification[]
}

model PatientProfile {
  id String @id @default(uuid())

  accountId String  @unique
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  firstName  String
  middleName String?
  lastName   String

  birthday DateTime

  weight Float?
  height Float?

  profilePicture String?

  phone   String?
  address String?

  emergencyName  String?
  emergencyPhone String?

  medicalHistory MedicalHistory[]

  appointments Appointment[]

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  consultationNotes ConsultationNote[]
  prescriptions     Prescription[]
}

model MedicalHistory {
  id String @id @default(uuid())

  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  condition String

  createdAt DateTime @default(now())
}

model DoctorProfile {
  id String @id @default(uuid())

  accountId String  @unique
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  firstName  String
  middleName String?
  lastName   String

  profilePicture String?

  bio String?

  schedules DoctorSchedule[]

  specializations DoctorSpecialization[]

  appointments Appointment[]

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  consultationNotes ConsultationNote[]
  prescriptions     Prescription[]
}

model Specialization {
  id String @id @default(uuid())

  name String @unique

  doctors DoctorSpecialization[]
}

model DoctorSpecialization {
  doctorId         String
  specializationId String

  doctor DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  specialization Specialization @relation(fields: [specializationId], references: [id], onDelete: Cascade)

  @@id([doctorId, specializationId])
}

model DoctorSchedule {
  id String @id @default(uuid())

  doctorId String
  doctor   DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  startTime DateTime
  endTime   DateTime

  appointments Appointment[]

  createdAt DateTime @default(now())

  @@index([doctorId])
}

model Appointment {
  id String @id @default(uuid())

  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  doctorId String
  doctor   DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  scheduleId String
  schedule   DoctorSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  reason String?

  status AppointmentStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  consultationSession ConsultationSession?
  consultationNote    ConsultationNote?
  prescription        Prescription?

  @@index([patientId])
  @@index([doctorId])
  @@index([scheduleId])
}

model ConsultationSession {
  id String @id @default(uuid())

  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  meetingLink     String
  meetingId       String?
  calendarEventId String? @unique

  status ConsultationSessionStatus @default(SCHEDULED)

  startedAt DateTime?
  endedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ConsultationNote {
  id String @id @default(uuid())

  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  doctorId String
  doctor   DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  summary         String
  findings        String?
  recommendations String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Prescription {
  id String @id @default(uuid())

  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  doctorId String
  doctor   DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  diagnosis    String?
  instructions String?
  medications  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id String @id @default(uuid())

  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  type NotificationType

  title    String
  message  String
  metadata Json?

  readAt DateTime?

  createdAt DateTime @default(now())

  @@index([accountId])
}
